<settings>
<category label="VIP">
	<setting label="CONFIGURAÇÕES DE ACESSO [COLOR gold](VIP)[/COLOR]" type="lsep"/>
	<setting id="servidor" type="labelenum" label="Selecione o Servidor" default="Desativado" values="OnePlay|Desativado"/>
	<setting id="username" type="text" label="Usuário" default="" enable="!eq(-1,false)"/>
	<setting id="password" type="text" label="Senha" default="" enable="!eq(-2,false)" option="hidden"/>
	<setting label="CONFIGURAÇÕES ADICIONAIS" type="lsep"/>
	<setting id="saida" type="labelenum" label="Saida de Transmissão VIP" default="ts" values="ts|m3u8"/>
	<setting id="exibirvip" type="bool" label="Exibir Menu VIP" default="true" />
</category>
<category label="CONFIGURAÇÕES">
	<setting label="CONFIGURAÇÕES GERAIS" type="lsep"/>
	<setting id="dlaudioonly" type="bool" label="Baixar apenas audio" default="false" />
    <setting id="use_thumb" type="bool" label="Use Miniaturas como Fanart" default="false" />
    <setting id="1080pquality" label="Reproduz vídeo 1080p sob demanda, se disponível (Não ao Vivo)" type="bool" default="true"/>
	<setting id="Updatecommonresolvers" type="bool" label="Atualizar Resolvedores Comuns" default="true"/>
    <setting id="logo-folderPath" type="folder"  label="Selecione o diretório para o logotipo." default=""/>
</category>
</settings>
